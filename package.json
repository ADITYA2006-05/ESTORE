{
  "name": "estore",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "build": "prisma generate && next build --webpack",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "create-admin": "tsx scripts/create-admin.ts",
    "seed": "tsx scripts/seed-products.ts",
    "build:cf": "prisma generate && opennextjs-cloudflare build && node scripts/purge-wasm.js",
    "deploy": "prisma generate && opennextjs-cloudflare build && node scripts/purge-wasm.js && opennextjs-cloudflare deploy",
    "preview": "prisma generate && opennextjs-cloudflare build && node scripts/purge-wasm.js && opennextjs-cloudflare preview",
    "upload": "prisma generate && opennextjs-cloudflare build && node scripts/purge-wasm.js && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@types/ws": "^8.18.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "wrangler": "^4.93.1"
  }
}
