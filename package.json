{
  "name": "estore",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "create-admin": "tsx scripts/create-admin.ts",
    "build:cf": "opennextjs-cloudflare build && node scripts/purge-wasm.js",
    "deploy": "opennextjs-cloudflare build && node scripts/purge-wasm.js && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && node scripts/purge-wasm.js && opennextjs-cloudflare preview",
    "upload": "opennextjs-cloudflare build && node scripts/purge-wasm.js && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^5.22.0",
